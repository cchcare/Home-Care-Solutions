# ============================================================
# Application Environment Variables
# Copy this file to .env and fill in the values.
# Variables marked [optional] have safe defaults and are not
# required for basic operation.
# ============================================================

# ---- Database ----
# PostgreSQL connection string (Neon, RDS, or any Postgres)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# ---- Auth / Session ----
# Random secret used to sign session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_secret

# JWT secret for mobile API tokens; falls back to SESSION_SECRET if not set [optional]
# JWT_SECRET=change_me_to_a_random_jwt_secret

# ---- App Config ----
# Publicly reachable base URL of the app (no trailing slash)
BASE_URL=https://app.carechc.com

# Node environment: "production" or "development"
NODE_ENV=production

# Port the Express server listens on [optional, default: 5000]
# PORT=5000

# Display name for the organization used in emails [optional]
# COMPANY_NAME=CCHC Solutions

# ---- Security / Encryption ----
# 32-byte hex key used to encrypt sensitive progress notes at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# [optional — notes stored unencrypted if not set, but strongly recommended in production]
# NOTES_ENCRYPTION_KEY=64_hex_chars_here

# ---- AWS ----
# S3 bucket name for file uploads (documents, profile photos, paystubs, help images)
# When unset, app falls back to local disk (development only)
AWS_S3_BUCKET=my-carechc-bucket

# AWS region where the S3 bucket lives [optional, default: us-east-1]
# AWS_S3_REGION=us-east-1

# AWS credentials — prefer IAM instance roles on EC2/ECS; only set for local dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Replit Object Storage paths (used for private/public file buckets on Replit)
# On AWS these are replaced by S3; leave unset unless using Replit object storage.
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=

# ---- Stripe ----
# Live or test secret key from Stripe dashboard
STRIPE_SECRET_KEY=sk_live_...

# Publishable key from Stripe dashboard (safe to expose to the browser)
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret (Stripe → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Twilio ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ---- AgentMail ----
# On Replit, AgentMail uses the Replit Connector (REPLIT_CONNECTORS_HOSTNAME + identity token).
# On AWS, set AGENTMAIL_API_KEY directly and the app will use it instead of the connector.
AGENTMAIL_API_KEY=your_agentmail_api_key
# Inbox is discovered automatically from the AgentMail API; no inbox ID env var needed.

# ---- OpenAI / AI Features ----
# On Replit, the AI integration supplies these automatically via the integration system.
# On AWS, set them directly. Used by OCR, AI assistant, kiosk face-match, exclusion checks.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ---- ADP Integration [optional] ----
# Required only if ADP payroll export/import features are enabled
# ADP_CLIENT_ID=your_adp_client_id
# ADP_CLIENT_SECRET=your_adp_client_secret
# ADP_ENVIRONMENT=production

# ---- Scheduler (Cron) ----
# All scheduler vars are optional — defaults shown below

# Birthday notification cron schedule [optional, default: "0 8 * * *"]
# BIRTHDAY_CRON_SCHEDULE=0 8 * * *

# Hour of day to send birthday notifications (24h) [optional, default: 8]
# BIRTHDAY_NOTIFICATION_HOUR=8

# Exclusion check cron schedule [optional, default: "0 2 1 * *"]
# EXCLUSION_CHECK_CRON=0 2 1 * *

# Expiration alert cron schedule [optional, default: "0 7 * * *"]
# EXPIRATION_ALERT_CRON=0 7 * * *

# ---- Replit OIDC / Google OAuth (Replit environment only) ----
# Only needed when running on Replit — omit on AWS.
# When absent, Replit OIDC auth is skipped; local username/password auth still works.
# REPLIT_DOMAINS=your-repl.repl.co,your-custom-domain.com
# REPL_ID=your-replit-app-id
# ISSUER_URL=https://replit.com/oidc

# Replit Connector credentials (used by AgentMail on Replit) — omit on AWS
# REPLIT_CONNECTORS_HOSTNAME=connectors.replit.com
# REPL_IDENTITY=<auto-set by Replit>
# WEB_REPL_RENEWAL=<auto-set by Replit>

# ---- HHAX SFTP [optional] ----
# Used for automated HHAX data imports via SFTP
# HHAX_SFTP_HOST=sftp.hhaxsystem.com
# HHAX_SFTP_USERNAME=your_sftp_username
# HHAX_SFTP_PASSWORD=your_sftp_password
# HHAX_SFTP_PORT=2222
# HHAX_TAX_ID=your_organization_tax_id

# ---- Vercel Cron ----
# Shared secret Vercel Cron sends as "Authorization: Bearer $CRON_SECRET" —
# generate with: openssl rand -hex 32. Required in production on Vercel.
CRON_SECRET=change_me_to_a_random_secret

# ---- OCR Service ----
# Base URL of the standalone ocr-service/ app (deployed separately, e.g. on
# Render/Fly/Railway, since it needs GraphicsMagick/Ghostscript which Vercel
# can't run). Shared secret must match that service's OCR_SERVICE_SECRET.
# OCR_SERVICE_URL=https://your-ocr-service.onrender.com
# OCR_SERVICE_SECRET=change_me_to_a_random_secret

# ---- Misc / Init ----
# Set to "true" on very first production deploy to seed initial DB data
# INIT_PRODUCTION_DB=true
